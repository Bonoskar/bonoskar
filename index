<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bonoskar | Productor Musical</title>
    <style>
        :root {
            --neon-cyan: #0fe0f5;
            --neon-purple: #9d4edd;
            --bg-dark: #0a0a0c;
            --card-bg: rgba(255, 255, 255, 0.03);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background-color: var(--bg-dark);
            background-image: radial-gradient(circle at 50% 0%, #1a1a24 0%, var(--bg-dark) 70%);
            color: #ffffff;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            padding: 2rem 1rem;
        }

        .container {
            width: 100%;
            max-width: 450px;
            text-align: center;
        }

        .avatar-container {
            position: relative;
            width: 150px;
            height: 150px;
            margin: 0 auto 1.5rem;
        }

        .avatar {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid var(--neon-cyan);
            box-shadow: 0 0 25px rgba(15, 224, 245, 0.4), inset 0 0 10px rgba(157, 78, 221, 0.5);
            transition: transform 0.3s ease;
        }

        .avatar:hover {
            transform: scale(1.05);
        }

        h1 {
            font-size: 2.2rem;
            font-weight: 800;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 0.2rem;
            background: linear-gradient(90deg, var(--neon-cyan), var(--neon-purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .tagline {
            font-size: 1rem;
            color: #888;
            margin-bottom: 2rem;
            font-weight: 300;
            letter-spacing: 1px;
        }

        .section-divider {
            font-size: 0.8rem;
            text-transform: uppercase;
            color: #555;
            letter-spacing: 2px;
            margin: 2rem 0 1rem;
            display: flex;
            align-items: center;
        }

        .section-divider::before,
        .section-divider::after {
            content: "";
            flex: 1;
            border-bottom: 1px solid #222;
        }

        .section-divider::before { margin-right: 10px; }
        .section-divider::after { margin-left: 10px; }

        .links-grid {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .link-btn {
            display: block;
            padding: 1rem;
            border-radius: 12px;
            background: var(--card-bg);
            color: #fff;
            text-decoration: none;
            font-weight: 600;
            letter-spacing: 0.5px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            position: relative;
            overflow: hidden;
        }

        .link-btn::before {
            content: '';
            position: absolute;
            top: 0; left: -100%; width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
            transition: left 0.5s ease;
        }

        .link-btn:hover::before {
            left: 100%;
        }

        .link-btn:hover {
            background: rgba(15, 224, 245, 0.08);
            border-color: rgba(15, 224, 245, 0.5);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3), 0 0 15px rgba(157, 78, 221, 0.2);
            transform: translateY(-3px);
        }

        /* Colores específicos por plataforma al hacer hover */
        .btn-spotify:hover { border-color: #1DB954; background: rgba(29, 185, 84, 0.1); box-shadow: 0 0 15px rgba(29, 185, 84, 0.2); }
        .btn-apple:hover { border-color: #FA243C; background: rgba(250, 36, 60, 0.1); box-shadow: 0 0 15px rgba(250, 36, 60, 0.2); }
        .btn-yt:hover { border-color: #FF0000; background: rgba(255, 0, 0, 0.1); box-shadow: 0 0 15px rgba(255, 0, 0, 0.2); }
        .btn-ig:hover { border-color: #E1306C; background: rgba(225, 48, 108, 0.1); box-shadow: 0 0 15px rgba(225, 48, 108, 0.2); }
        .btn-tk:hover { border-color: #00f2fe; background: rgba(0, 242, 254, 0.1); box-shadow: 0 0 15px rgba(0, 242, 254, 0.2); }
        
        footer {
            margin-top: 3rem;
            font-size: 0.8rem;
            color: #444;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="avatar-container">
            <img src="Bonoskar.jpg" alt="Bonoskar Logo" class="avatar">
        </div>
        
        <h1>Bonoskar</h1>
        <p class="tagline">Productor Musical</p>

        <div class="section-divider">Música</div>
        <div class="links-grid">
            <a href="https://open.spotify.com/artist/0KDZliFpT1uF6uCMl2oI71?si=rJat5GSOQLeMtSrD7Vk5rg" class="link-btn btn-spotify" target="_blank" rel="noopener noreferrer">Spotify</a>
            <a href="https://music.apple.com/es/artist/bonoskar/1871603922?ls" class="link-btn btn-apple" target="_blank" rel="noopener noreferrer">Apple Music</a>
        </div>

        <div class="section-divider">Comunidad</div>
        <div class="links-grid">
            <a href="https://www.youtube.com/@bonoskar_music" class="link-btn btn-yt" target="_blank" rel="noopener noreferrer">YouTube</a>
            <a href="https://www.instagram.com/bonoskar/" class="link-btn btn-ig" target="_blank" rel="noopener noreferrer">Instagram</a>
            <a href="https://www.tiktok.com/@bonoskar_music" class="link-btn btn-tk" target="_blank" rel="noopener noreferrer">TikTok</a>
            <a href="https://x.com/bonoskar" class="link-btn" target="_blank" rel="noopener noreferrer">X (Twitter)</a>
        </div>

        <footer>
            &copy; 2026 Bonoskar. Todos los derechos reservados.
        </footer>
    </div>

</body>
</html>
